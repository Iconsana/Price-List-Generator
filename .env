# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-app-url.railway.app

# Development Configuration
DEV_STORE_URL=your-dev-store.myshopify.com
NGROK_URL=https://your-ngrok-url.ngrok.io

# Database Configuration (Optional - using memory storage for now)
# DATABASE_URL=postgresql://user:password@localhost:5432/price_list_generator

# Environment
NODE_ENV=production
PORT=3000

# Security
SESSION_SECRET=your_session_secret_here

# Optional: PDF Generation Service
PDF_SERVICE_URL=https://your-pdf-service.com

# Optional: File Upload Service
UPLOAD_SERVICE_URL=https://your-upload-service.com

# Shopify Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_here

# Frontend Build Configuration
VITE_SHOPIFY_API_KEY=your_api_key_here
VITE_APP_URL=https://your-app-url.railway.app
